<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <!-- Supplier Receipt Form  -->
        <record id="view_account_payment_group_form" model="ir.ui.view">
            <field name="name">account.payment.group.form</field>
            <field name="model">account.payment.group</field>
            <field name="inherit_id" ref="account_payment_group.view_account_payment_group_form"/>
            <field name="arch" type="xml">
                <!-- ahora hacemos que en borrador tmb se puedan computar las retenciones -->
                <field name="unreconciled_amount" position="attributes">
                    <!--TODO: Result from 'attrs' -> 'invisible' conversion without also overriding 'states' attribute
                         Check if this field tag contained a states attribute in any of the parent views, in which case it should be combined into this 'invisible' attribute
                         (If any states attributes existed in parent views, they'll also be marked with a TODO)-->
                    <attribute name="invisible">partner_type != 'supplier' or state not in ['draft', 'confirmed']</attribute>
                    <!--TODO: Result from converting 'attrs' attribute override without options for ['required', 'readonly', 'column_invisible'] to separate attributes
                         Remove redundant empty tags below for any of those attributes that are not present in the field tag in any of the parent views
                         If someone later adds one of these attributes in the parent views, they would likely be unaware it's still overridden in this view, resulting in unexpected behaviour, which should be avoided-->
                    <attribute name="required"/>
                    <attribute name="readonly"/>
                    <attribute name="column_invisible"/>
                </field>
                <field name="to_pay_amount" position="attributes">
                    <!--TODO: Result from 'attrs' -> 'invisible' conversion without also overriding 'states' attribute
                         Check if this field tag contained a states attribute in any of the parent views, in which case it should be combined into this 'invisible' attribute
                         (If any states attributes existed in parent views, they'll also be marked with a TODO)-->
                    <attribute name="invisible">partner_type != 'supplier' or state not in ['draft', 'confirmed']</attribute>
                    <!--TODO: Result from converting 'attrs' attribute override without options for ['required', 'readonly', 'column_invisible'] to separate attributes
                         Remove redundant empty tags below for any of those attributes that are not present in the field tag in any of the parent views
                         If someone later adds one of these attributes in the parent views, they would likely be unaware it's still overridden in this view, resulting in unexpected behaviour, which should be avoided-->
                    <attribute name="required"/>
                    <attribute name="readonly"/>
                    <attribute name="column_invisible"/>
                </field>
                        <field name="to_pay_amount" options="{'currency_field': 'currency_id'}"/>
                <button position="before">
                    <!-- <button name="compute_withholdings" string="Compute Withholdings" type="object" states="confirmed"/> -->
                    <button name="compute_withholdings" string="Compute Withholdings" type="object" invisible="partner_type != 'supplier' or state not in ['draft', 'confirmed']"/>
                </button>

                <field name="unreconciled_amount" position="after">
                    <field name="withholdable_advanced_amount" options="{'currency_field': 'currency_id'}" invisible="unreconciled_amount &lt;= 0.0 or partner_type != 'supplier' or state not in ['draft', 'confirmed']"/>
                </field>
            </field>
        </record>

    </data>
</odoo>