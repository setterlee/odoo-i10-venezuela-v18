<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="view_move_form" model="ir.ui.view">
            <field name="name">account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page name="igtf_purchase" string="Igtf compras" invisible="move_type not in ['in_invoice', 'in_refund']">
                        <group>
                            <field name="igtf_purchase_apply_purchase" readonly="state != 'draft'"/>
                            <field name="igtf_base_purchase" readonly="state != 'draft'" invisible="not igtf_purchase_apply_purchase"/>
                            <field name="igtf_amount_purchase" readonly="state != 'draft'" invisible="not igtf_purchase_apply_purchase"/>
                            <field name="igtf_base_purchase_usd" readonly="state != 'draft'" invisible="not igtf_purchase_apply_purchase"/>
                            <field name="igtf_amount_purchase_usd" readonly="state != 'draft'" invisible="not igtf_purchase_apply_purchase"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>