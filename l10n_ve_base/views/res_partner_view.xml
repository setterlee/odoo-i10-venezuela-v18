<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
      <!-- View form of res_partner -->
      <record id="view_res_partner_form_inherit" model="ir.ui.view">
        <field name="name">res_partner_form_inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="type">form</field>
        <field name="arch" type="xml">
          <xpath expr="//div[hasclass('o_address_format')]" position="replace">
            <div class="o_address_format">
                <field name="country_id" placeholder="Country" class="o_address_country" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}" readonly="type == 'contact' and parent_id"/>
                <field name="state_id" class="o_address_state" placeholder="State" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}" readonly="type == 'contact' and parent_id" context="{'country_id': country_id, 'zip': zip}"/>
                <field name="municipality_id" placeholder="Municipio" class="o_address_city" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}" domain="[('state_id', '=', state_id)]"/>
                <field name="city" placeholder="Ciudad" class="o_address_city" readonly="type == 'contact' and parent_id"/>
                <field name="parish_id" placeholder="Parroquia" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}" class="o_address_state" domain="[('municipality_id', '=', municipality_id)]"/>
                <field name="zip" placeholder="ZIP" class="o_address_zip" readonly="type == 'contact' and parent_id"/>
                <field name="street" placeholder="Calle..." class="o_address_street" readonly="type == 'contact' and parent_id"/>
                <field name="street2" placeholder="Calle 2..." class="o_address_street" readonly="type == 'contact' and parent_id"/>
            </div>
          </xpath>
          <xpath expr="//field[@name='bank_ids']" position="replace">
              <field name="bank_ids">
                <list editable="bottom">
                    <field name="bank_id"/>
                    <field name="acc_number"/>
                    <field name="l10n_ve_acc_type"/>
                    <field name="acc_holder_name" invisible="1"/>
                </list>
              </field>
          </xpath>
          <field name="vat" position="after">
                <field name="l10n_ve_responsibility_type_id" string="SENIAT Responsibility" options="{'no_open': True, 'no_create': True}" readonly="parent_id"/>
          </field>
        </field>
      </record>
    </data>
  </odoo>