<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data> 
    <!-- Supplier Receipt Form  -->
        <record id="view_account_payment_group_form" model="ir.ui.view">
            <field name="name">account.payment.group.form</field>
            <field name="model">account.payment.group</field>
            <field name="inherit_id" ref="account_payment_group.view_account_payment_group_form"/>
            <field name="arch" type="xml">
                <form>
                    <field name="partner_regimen_islr_ids" invisible="1"/>
                </form>
                <field name="communication" position="after">
                    <field name="iva"/>
                    <field name="islr" invisible="not partner_regimen_islr_ids"/>
                    <field name="withholding_distributin_islr" invisible="not islr" required="islr and state in ['draft', 'confirmed']"/>
                    <field name="regimen_islr_id" invisible="not islr or withholding_distributin_islr" required="islr and not withholding_distributin_islr and state in ['draft', 'confirmed']" domain="[('id', 'in', partner_regimen_islr_ids)]" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"/>
                    <field name="third_partner_withholding" widget="boolean_toggle" invisible="not iva and not islr" readonly="state == 'posted'"/>
                    <field name="third_partner_id" invisible="not third_partner_withholding" required="third_partner_withholding" readonly="state == 'posted'"/>
                </field>
                <field name="selected_debt" position="replace">
                    <field name="debt_multicurrency" invisible="1"/>
                    <field name="selected_debt_currency_id" invisible="1"/>
                    <field name="selected_debt" invisible="state not in ['draft', 'confirmed']" options="{'currency_field': 'currency_id'}"/>
                    <field name="selected_finacial_debt" invisible="not debt_multicurrency or state not in ['draft', 'confirmed']" options="{'currency_field': 'currency_id'}"/>
                    <field name="selected_finacial_debt_currency" invisible="not debt_multicurrency or state not in ['draft', 'confirmed']" options="{'currency_field': 'selected_debt_currency_id'}"/>
                </field>

                <xpath expr="//button[@name='compute_withholdings']" position="replace">

                    <button name="compute_withholdings" string="Calcular Retenciones" type="object" confirm="El computar la retención realizara un solo registro por la factura correspondiente, para ello solo puede pagar una factura a la vez." invisible="partner_type != 'supplier' or state not in ['draft', 'confirmed'] or not iva and not islr"/>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page name="withholding_distributin_islr" string="Distribucion ISLR" invisible="not withholding_distributin_islr">
                        <group colspan="2">
                            <field name="withholding_distributin_islr_ids">
                                <list string="Lineas de factura" create="false" delete="0" editable="bottom">
                                    <field name="payment_group_id" invisible="1"/>
                                    <field name="move_line_id" invisible="1"/>
                                    <field name="product_id"/>
                                    <field name="price_subtotal"/>
                                    <field name="currency_id"/>
                                    <field name="regimen_islr_id" domain="[('id', 'in', partner_regimen_islr_ids)]"/>
                                    <field name="partner_regimen_islr_ids" invisible="1"/>
                                </list>
                            </field>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>